:{$PORT}

root * /srv
encode gzip zstd
file_server

# images can cache long; code (css/js) revalidates hourly — index.html carries
# ?v= stamps on every code link, so each deploy busts phone caches instantly
@imgs path /assets/*
header @imgs Cache-Control "public, max-age=2592000"
@code path /css/* /js/*
header @code Cache-Control "public, max-age=3600"
header /index.html Cache-Control "no-cache"
header / Cache-Control "no-cache"
